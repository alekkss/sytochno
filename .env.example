# =============================================================================
# Sutochno Parser — переменные окружения
# =============================================================================
# Скопируйте этот файл в .env и заполните обязательные переменные:
#   Windows: copy .env.example .env
#   macOS/Linux: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# ОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ
# -----------------------------------------------------------------------------

# URL страницы поиска sutochno.ru с нужными фильтрами
SUTOCHNO_SEARCH_URL=https://sutochno.ru/front/searchapp/search?guests_adults=2&occupied=2026-05-05;2026-05-06&term=%D0%A1%D0%B0%D0%BD%D0%BA%D1%82-%D0%9F%D0%B5%D1%82%D0%B5%D1%80%D0%B1%D1%83%D1%80%D0%B3&id=397367&type=city&SW.lat=59.77977557614511&SW.lng=30.026817069335937&NE.lat=60.055581373598486&NE.lng=30.582999930664045&price_per=1&is_studio=1&is_apartment=1

# -----------------------------------------------------------------------------
# НЕОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ (значения по умолчанию указаны после =)
# -----------------------------------------------------------------------------

# Запуск браузера без графического интерфейса (true/false)
# false — вы увидите окно браузера, true — браузер работает в фоне
HEADLESS_MODE=true

# Максимальное количество страниц для парсинга (0 = все доступные страницы)
MAX_PAGES=1

# Таймаут навигации в миллисекундах
NAVIGATION_TIMEOUT=60000

# Минимальная пауза между действиями в миллисекундах (защита от детекции бота)
MIN_DELAY_MS=2000

# Максимальная пауза между действиями в миллисекундах
MAX_DELAY_MS=5000

# -----------------------------------------------------------------------------
# ПАРАЛЛЕЛЬНЫЕ ВКЛАДКИ (ускорение обработки карточек)
# -----------------------------------------------------------------------------

# Количество параллельных вкладок в одном браузере
# Каждая вкладка обрабатывает свою карточку независимо
# При USE_PROXY=true — каждый прокси-браузер открывает MAX_TABS вкладок
# Пример: 10 прокси × 5 вкладок = до 50 карточек одновременно
# Рекомендуется 3–5 для стабильной работы
MAX_TABS=5

# Пауза между запуском вкладок в миллисекундах
# Распределяет нагрузку на сеть — вкладки стартуют не одновременно,
# а с интервалом TAB_DELAY_MS между ними
# Рекомендуется 2000–5000 мс
TAB_DELAY_MS=3000

# -----------------------------------------------------------------------------
# ХРАНИЛИЩЕ И ЭКСПОРТ
# -----------------------------------------------------------------------------

# Путь к базе данных SQLite
DB_PATH=data/sutochno_listings.db

# Путь к выходному Excel-файлу
EXPORT_PATH=data/sutochno_report.xlsx

# -----------------------------------------------------------------------------
# ЛОГИРОВАНИЕ
# -----------------------------------------------------------------------------

# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=DEBUG

# Путь к файлу логов (пусто = только консоль)
LOG_FILE_PATH=logs/app.log

# -----------------------------------------------------------------------------
# ПРОКСИ (для параллельной обработки карточек)
# -----------------------------------------------------------------------------

# Использовать прокси для парсинга карточек (true/false)
# true — карточки обрабатываются параллельно через несколько прокси-браузеров
# false — обработка через один браузер (с параллельными вкладками, если MAX_TABS > 1)
USE_PROXY=true

# Путь к файлу со списком прокси
# Формат каждой строки: ip:port:login:password
# Пример: 194.28.193.202:11223:fwrBfkVyVw:Bw3BKDfzNp
PROXIES_PATH=data/proxies.txt

# Максимальное количество одновременных прокси-браузеров
# Если рабочих прокси больше этого числа — используются только первые N
# Каждый прокси-браузер открывает MAX_TABS вкладок
# Рекомендуется 3–7 для стабильной работы
MAX_PROXY_WORKERS=5
